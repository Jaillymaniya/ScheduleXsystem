@page "/reset-password"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager nav

<link href="css/auth.css" rel="stylesheet" />

<div class="auth-container">
    <div class="auth-box">
        <h2>Reset Password</h2>

        <input type="password" @bind="NewPassword" placeholder="New Password" />
        <input type="password" @bind="ConfirmPassword" placeholder="Confirm Password" />

        <button @onclick="Reset">Reset Password</button>

        <p class="message">@Message</p>
    </div>
</div>

@code {
    string NewPassword;
    string ConfirmPassword;
    string Message;

    async Task Reset()
    {
        if (NewPassword != ConfirmPassword)
        {
            Message = "❌ Passwords do not match";
            return;
        }

        var res = await Http.PostAsJsonAsync("api/account/reset-password",
            new { NewPassword });

        if (res.IsSuccessStatusCode)
        {
            Message = "✅ Password reset successful";
            await Task.Delay(1000);
                nav.NavigateTo("/login?msg=reset-success");
        }
        else
        {
            Message = "❌ Failed to reset password";
        }
    }
}