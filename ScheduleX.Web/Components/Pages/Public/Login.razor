@rendermode InteractiveServer
@page "/login"

@using ScheduleX.Core.Entities
@using Microsoft.AspNetCore.Identity

@inject NavigationManager Nav
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@inject HttpClient Http
@inject IJSRuntime JS

<link href="css/login.css" rel="stylesheet" />

<button class="circle-back-btn" @onclick="GoHome">
    ←
</button>

<div class="auth-container">

    <!-- LEFT -->
    <div class="auth-left">
        <h1>ScheduleX</h1>
        <h3>Timetable Generator</h3>
        <p>
            Smart academic scheduling for institutions, faculty,
            and students — fast, accurate, and automated.
        </p>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="login-card">

            <h2>Sign in</h2>
            <p class="subtitle">Access your ScheduleX dashboard</p>

            @if (!string.IsNullOrEmpty(Error))
            {
                <div class="server-error">@Error</div>
            }

            <br />

            <!-- 🔥 FORM START -->
            <form method="post" action="/api/auth/login">

                <!-- USERNAME -->
                <input class="input"
                       name="Username"
                       placeholder="Username or Email"
                       required />

                <!-- PASSWORD -->
                <div class="password-wrapper">
                    <input type="@(_showPassword ? "text" : "password")"
                           class="input password-input"
                           name="Password"
                           placeholder="Password"
                           required />

                    <button type="button" class="toggle-eye" @onclick="TogglePassword">
                        <i class="@(_showPassword ? "fa-solid fa-eye-slash" : "fa-solid fa-eye")"></i>
                    </button>
                </div>

                <!-- BUTTON -->
                @* <button class="btn primary" type="submit"> *@
                @*     Sign in *@
                @* </button> *@
                <button class="btn primary" type="submit" disabled="@isLocked">
                    @(isLocked ? $"Locked ({remainingSeconds}s)" : "Sign in")
                </button>

                <!-- FORGOT -->
                <div class="forgot">
                    <a href="/forgot-password" class="forgot-link">Forgot password?</a>
                </div>

            </form>
            <!-- 🔥 FORM END -->

        </div>
    </div>

</div>

@if (showRobotCheck)
{
    <div class="overlay">
        <div class="robot-box">
            <h3>🤖 Verification Required</h3>
            <p>Are you a human?</p>

            <label>
                <input type="checkbox" @onchange="VerifyHuman" />
                I'm not a robot
            </label>
        </div>
    </div>
}

@code {
    class LoginResponse
    {
        public string Role { get; set; }
    }
    private string Username = "";
    private string Password = "";
    private string Error = "";

    private bool _busy;
    private bool showUserError;
    private bool showPassError;
    private bool _showPassword = false;

    private string returnUrl = "/";

    //login wrong attempt
    private int failedAttempts = 0;
    private bool showRobotCheck = false;
    private bool isLocked = false;
    private int remainingSeconds = 0;
    private System.Timers.Timer? lockTimer;
    private bool shouldHandleFailure = false;


    private async Task LockLogin()
    {
        isLocked = true;
        remainingSeconds = 30;

        await JS.InvokeVoidAsync("setLock", 30);

        StartTimer();
    }

    private void StartTimer()
    {
        lockTimer?.Stop(); // 🔥 prevent multiple timers

        lockTimer = new System.Timers.Timer(1000);
        lockTimer.Elapsed += (s, e) =>
        {
            remainingSeconds--;

            if (remainingSeconds <= 0)
            {
                lockTimer.Stop();
                isLocked = false;
                failedAttempts = 0;

                InvokeAsync(StateHasChanged);
            }
            else
            {
                InvokeAsync(StateHasChanged);
            }
        };

        lockTimer.Start();
    }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    private async Task DoLogin()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(Username))
            showUserError = true;

        if (string.IsNullOrWhiteSpace(Password))
            showPassError = true;

        if (showUserError || showPassError)
            return;

        if (_busy) return;
        _busy = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", new
            {
                Username,
                Password
            });

            if (!response.IsSuccessStatusCode)
            {
                Error = await response.Content.ReadAsStringAsync();
                return;
            }

            var json = await response.Content.ReadAsStringAsync();

            var result = System.Text.Json.JsonSerializer.Deserialize<LoginResponse>(
                json,
                new System.Text.Json.JsonSerializerOptions
                    {
                        PropertyNameCaseInsensitive = true
                    });

            var target = result.Role == "Admin"
                ? "/admin/overview"
                : "/tt/overview";

            // 🔥 MOST IMPORTANT LINE
            Nav.NavigateTo(target, forceLoad: true);
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void ClearMessages(ChangeEventArgs? e = null)
    {
        showUserError = false;
        showPassError = false;
        Error = "";
    }

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        // 🔥 detect failed login
        if (query.TryGetValue("error", out var error))
        {
            if (error == "invalid")
            {
                // await HandleFailedAttempt();
                // ✅ CALL HERE
                shouldHandleFailure = true; // ✅ delay
            }
        }


        if (query.TryGetValue("ReturnUrl", out var url))
        {
            returnUrl = url!;
        }

        // return Task.CompletedTask;

    }

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }

    private async Task VerifyHuman(ChangeEventArgs e)
    {
        showRobotCheck = false;
        failedAttempts = 1;

        await JS.InvokeVoidAsync("setAttempts", 1);

        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // ✅ restore lock
            var remaining = await JS.InvokeAsync<int>("getLockRemaining");
            if (remaining > 0)
            {
                isLocked = true;
                remainingSeconds = remaining;
                StartTimer();
            }

            // ✅ restore robot
            // showRobotCheck = await JS.InvokeAsync<bool>("getRobotCheck");

            // ✅ handle failed attempt safely
            if (shouldHandleFailure)
            {
                shouldHandleFailure = false;
                await HandleFailedAttempt();
            }

            // if no error param → reset attempts
            var uri = Nav.ToAbsoluteUri(Nav.Uri);

            if (!uri.Query.Contains("error"))
            {
                await JS.InvokeVoidAsync("resetAttempts");
            }

            await InvokeAsync(StateHasChanged);

        }
    }

    // private async Task HandleFailedAttempt()
    // {
    //     failedAttempts = await JS.InvokeAsync<int>("getAttempts");
    //     failedAttempts++;

    //     await JS.InvokeVoidAsync("setAttempts", failedAttempts);

    //     Error = "Invalid username or password";

    //     if (failedAttempts == 2)
    //     {
    //         showRobotCheck = true;
    //         await JS.InvokeVoidAsync("setRobotCheck", true);
    //     }

    //     if (failedAttempts >= 3)
    //     {
    //         await LockLogin();
    //     }

    //     await InvokeAsync(StateHasChanged);

    // }

    private async Task HandleFailedAttempt()
    {
        failedAttempts = await JS.InvokeAsync<int>("getAttempts");
        failedAttempts++;

        await JS.InvokeVoidAsync("setAttempts", failedAttempts);

        Error = "Invalid username or password";

        if (failedAttempts == 2)
        {
            showRobotCheck = true;

            // 🔥 IMPORTANT: force UI refresh immediately
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (failedAttempts >= 3)
        {
            await LockLogin();
        }

        await InvokeAsync(StateHasChanged);
    }

}