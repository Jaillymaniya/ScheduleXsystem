@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav

<div class="tt-topbar-inner">

    <!-- LEFT -->
    <div class="tt-topbar-left">
        <div class="tt-title">TT Coordinator Dashboard</div>
        <div class="tt-subtitle">Manage setup • configure • generate • export</div>
    </div>

    <!-- CENTER -->
    <div class="tt-topbar-center">
        <span class="tt-badge">Department: Computer</span>
        <span class="tt-badge">Course: BCA</span>
        <span class="tt-badge muted">Semester: 4</span>
    </div>

    <!-- RIGHT -->
    <div class="tt-topbar-right">

        <button class="tt-btn ghost"
                @onclick="@(()=>Nav.NavigateTo("/tt/account/profile"))">
            Profile
        </button>

        <button class="tt-btn ghost"
                @onclick="@(()=>Nav.NavigateTo("/tt/account/change-password"))">
            Change Password
        </button>

        <!-- ✅ SAME LOGOUT AS ADMIN -->
        <form method="post"
              action="/api/auth/logout"
              data-enhance="false"
              style="display:inline;">

            <button type="submit" class="tt-btn danger">
                Logout
            </button>

        </form>

    </div>

</div>