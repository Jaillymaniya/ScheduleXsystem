@inject NavigationManager Nav
@inject ScheduleX.Web.Services.AuthState Auth

<div class="admin-topbar">

    <!-- Dynamic Title -->
    <div class="dashboard-title">
        @PageTitle
    </div>

    <!-- Profile Icon -->
    <div class="profile-wrapper">

        <div class="profile-btn" @onclick="GoToProfile">
            @UserInitial
        </div>

    </div>

</div>

@code {

    private string PageTitle = "Dashboard";
    private string UserInitial = "A";

    protected override void OnInitialized()
    {
        SetTitle();
        SetInitial();

        Nav.LocationChanged += (s, e) =>
        {
            SetTitle();
            StateHasChanged();
        };
    }

    private void SetTitle()
    {
        var uri = Nav.ToBaseRelativePath(Nav.Uri);
        var segments = uri.Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (segments.Length > 1)
        {
            var last = segments.Last();
            PageTitle = FormatTitle(last);
        }
        else
        {
            PageTitle = "Dashboard";
        }
    }

    private string FormatTitle(string value)
    {
        value = value.Replace("-", " ");

        if (value.ToLower() == "ttcoordinator")
            return "Timetable Coordinator";

        return System.Globalization.CultureInfo.CurrentCulture.TextInfo
            .ToTitleCase(value);
    }

    private void SetInitial()
    {
        if (!string.IsNullOrEmpty(Auth.FullName))
            UserInitial = Auth.FullName.Substring(0, 1).ToUpper();
    }

    private void GoToProfile()
    {
        Nav.NavigateTo("/admin/edit-profile");
    }
}