@using Microsoft.AspNetCore.Components.Routing

<div class="admin-sidebar">

    <!-- LOGO -->
    <div class="logo">
        <img src="images/logo.png" alt="ScheduleX Logo" />
        <h3 class="logo-text">ScheduleX</h3>
    </div>

    <!-- MENU -->
    <ul>
        <!-- DASHBOARD -->
        <li>
            <NavLink href="/admin/overview">Dashboard</NavLink>
        </li>

        <!-- ACADEMIC STRUCTURE -->
        <li class="menu-heading">Academic Structure</li>
        <li><NavLink href="/admin/academic-year">Academic Year</NavLink></li>
        <li><NavLink href="/admin/departments">Departments</NavLink></li>
        <li><NavLink href="/admin/courses">Courses</NavLink></li>
        <li><NavLink href="/admin/semesters">Semesters</NavLink></li>

        <!-- CURRICULUM -->
        <li class="menu-heading">Curriculum</li>
        <li><NavLink href="/admin/subjects">Subjects</NavLink></li>

        <!-- STAFF MANAGEMENT -->
        <li class="menu-heading">Staff Management</li>
        <li><NavLink href="/admin/faculty">Faculty</NavLink></li>
        <li><NavLink href="/admin/ttcoordinator">TT Coordinators</NavLink></li>

        <!-- SETTINGS -->
        <li class="menu-heading">Settings</li>
        <li><NavLink href="/admin/edit-profile">Profile</NavLink></li>
        <li><NavLink href="/admin/change-password">Change Password</NavLink></li>
    </ul>

    <!-- ✅ SIMPLE LOGOUT BUTTON -->
    <div class="logout-section">

        <form method="post"
              action="/api/auth/logout"
              data-enhance="false">

            <button type="submit" class="logout-btn">
                Logout
            </button>

        </form>

    </div>

</div>
